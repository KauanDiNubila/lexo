generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ADVOGADO
  SECRETARIA
}

enum CaseStatus {
  ATIVO
  SUSPENSO
  ARQUIVADO
  ENCERRADO
}

enum DeadlineType {
  PRAZO
  AUDIENCIA
  REUNIAO
  OUTRO
}

enum DeadlineStatus {
  PENDENTE
  CONCLUIDO
  PERDIDO
}

enum InvoiceStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

model Organization {
  id                   String    @id @default(cuid())
  name                 String
  plan                 String    @default("trial")
  trialEndsAt          DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users        User[]
  invites      UserInvite[]
  auditLogs    AuditLog[]
  clients      Client[]
  cases        Case[]
  deadlines    Deadline[]
  invoices     Invoice[]
  activityLogs ActivityLog[]
}

model User {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  email             String       @unique
  passwordHash      String
  role              Role         @default(ADVOGADO)
  totpSecret        String?
  totpEnabled       Boolean      @default(false)
  totpPendingSecret String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  casesResponsavel Case[] @relation("CaseResponsavel")

  @@index([organizationId])
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  document       String?
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  cases    Case[]
  invoices Invoice[]

  @@index([organizationId])
}

model Case {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  number         String
  area           String?
  status         CaseStatus   @default(ATIVO)
  description    String?

  responsavelId String?
  responsavel   User?   @relation("CaseResponsavel", fields: [responsavelId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deadlines    Deadline[]
  invoices     Invoice[]
  activityLogs ActivityLog[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([clientId])
  @@index([responsavelId])
  @@index([status])
}

model Deadline {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseId         String
  case           Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type           DeadlineType   @default(PRAZO)
  status         DeadlineStatus @default(PENDENTE)
  title          String
  description    String?
  date           DateTime
  notifiedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([caseId])
  @@index([date])
  @@index([status])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caseId         String?
  case           Case?         @relation(fields: [caseId], references: [id])
  description    String
  amount         Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus @default(PENDENTE)
  dueDate        DateTime
  paidAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([clientId])
  @@index([dueDate])
  @@index([status])
}

model UserInvite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String
  role           Role         @default(ADVOGADO)
  token          String       @unique @default(cuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([token])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  userName       String
  action         String
  entityType     String?
  entityId       String?
  description    String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([createdAt])
}

// Rate limiting persistido (janela deslizante). Sem dependência paga (Redis/Upstash);
// usa o próprio Postgres. Linhas expiradas são limpas a cada checagem da mesma chave.
model RateHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseId         String
  case           Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId         String?
  userName       String
  action         String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([caseId])
  @@index([createdAt])
}
